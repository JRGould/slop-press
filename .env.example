# OpenAI-compatible endpoint. Works with:
#   - OpenAI: https://api.openai.com/v1
#   - Anthropic (OpenAI-compat): https://api.anthropic.com/v1
#   - Ollama: http://localhost:11434/v1
#   - LM Studio: http://localhost:1234/v1
#   - vLLM: http://localhost:8000/v1
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Per-request-type models. Both default to SLOPPRESS_MODEL if unset.
# Falls back to "gpt-4o-mini" if nothing is set.
SLOPPRESS_MODEL=gpt-5.4-nano
# SLOPPRESS_MODEL_READ=gpt-5.4-nano
SLOPPRESS_MODEL_ADMIN=gpt-5.4-mini

# Image generation — separate provider (can differ from chat).
# Defaults to the same OPENAI_API_KEY / OPENAI_BASE_URL if unset.
# SLOPPRESS_IMAGE_API_KEY=sk-...
# SLOPPRESS_IMAGE_BASE_URL=https://api.openai.com/v1
SLOPPRESS_IMAGE_MODEL=gpt-image-1-mini

# Dev mode is toggled by the npm scripts — `npm run dev` / `npm run docker:dev`
# set SLOPPRESS_DEV_MODE=true. Leave it out of this file.

# Bind address and port.
PORT=8080
HOST=0.0.0.0
HOSTNAME=localhost
SLOPPRESS_SITE_URL=http://localhost:8080
