# OpenAI-compatible endpoint. Works with:
#   - OpenAI: https://api.openai.com/v1
#   - Anthropic (OpenAI-compat): https://api.anthropic.com/v1
#   - Ollama: http://localhost:11434/v1
#   - LM Studio: http://localhost:1234/v1
#   - vLLM: http://localhost:8000/v1
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Per-request-type models. Both default to SLOPPRESS_MODEL if unset.
# Falls back to "gpt-4o-mini" if nothing is set.
SLOPPRESS_MODEL=gpt-4o-mini
# SLOPPRESS_MODEL_READ=gpt-4o-mini
# SLOPPRESS_MODEL_ADMIN=gpt-4o

# Dev mode: wraps every request in a streaming activity-panel SPA loader.
SLOPPRESS_DEV_MODE=false

# Bind address and port.
PORT=8080
HOST=0.0.0.0
